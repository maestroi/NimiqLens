# Homelab deployment stack — pulls the prebuilt images from GHCR (see
# .github/workflows/docker-build.yml) instead of building locally.
#
# Usage:
#   cp docker-compose.homelab.yml.example docker-compose.homelab.yml
#   # edit the domains and image owner below, then:
#   docker stack deploy -c docker-compose.homelab.yml nimlens
#
# docker-compose.homelab.yml is gitignored so your real domains stay out of
# the public repo.
#
# Assumes an external Traefik instance with:
#   - an HTTPS entrypoint named "websecure"
#   - a certificate resolver named "letsencrypt"
#   - an external Docker network named "traefik"
# Adjust the deploy.labels below if your Traefik setup differs.

services:
  backend:
    image: ghcr.io/<github-username>/nimlens-backend:latest
    environment:
      - PORT=8787
      - COINGECKO_API_BASE=https://api.coingecko.com/api/v3
      - NIMIQ_RPC_URL=https://rpc-mainnet.nimiqscan.com
      - ALLOWED_ORIGIN=https://nimiqlens.example.com,https://maestroi.github.io
    networks:
      - traefik
    deploy:
      restart_policy:
        condition: any
      labels:
        - traefik.enable=true
        - traefik.http.routers.nimlens-api.rule=Host(`api-nimiqlens.example.com`)
        - traefik.http.routers.nimlens-api.entrypoints=websecure
        - traefik.http.routers.nimlens-api.tls.certresolver=letsencrypt
        - traefik.http.services.nimlens-api.loadbalancer.server.port=8787

  frontend:
    # Build with the public API URL baked in (Swarm cannot resolve internal service DNS
    # from nginx, and the frontend calls the Traefik API host directly):
    #   docker build --build-arg VITE_API_BASE_URL=https://api-nimiqlens.example.com \
    #     -t ghcr.io/<github-username>/nimlens-frontend:latest ./frontend
    # Or set the VITE_API_BASE_URL repo variable in GitHub Actions.
    image: ghcr.io/<github-username>/nimlens-frontend:latest
    networks:
      - traefik
    deploy:
      restart_policy:
        condition: any
      labels:
        - traefik.enable=true
        - traefik.http.routers.nimlens.rule=Host(`nimiqlens.example.com`)
        - traefik.http.routers.nimlens.entrypoints=websecure
        - traefik.http.routers.nimlens.tls.certresolver=letsencrypt
        - traefik.http.services.nimlens.loadbalancer.server.port=80

networks:
  traefik:
    external: true
